#!/usr/bin/env bash
set -euo pipefail

source "$(dirname -- "${BASH_SOURCE[0]}")/common"

if [[ "$(uname -s)" != "Darwin" ]]; then
  printf '%s\n' "Telegram Personal setup currently supports macOS only." >&2
  exit 69
fi

PYTHON_VERSION="$(python3 -c 'import sys; print(sys.version_info.major, sys.version_info.minor)')"
read -r PYTHON_MAJOR PYTHON_MINOR <<< "$PYTHON_VERSION"
if [[ ! "$PYTHON_MAJOR" =~ ^[0-9]+$ ]] \
  || [[ ! "$PYTHON_MINOR" =~ ^[0-9]+$ ]] \
  || (( PYTHON_MAJOR != 3 || PYTHON_MINOR < 11 || PYTHON_MINOR > 14 )); then
  printf '%s\n' "Telegram Personal requires Python 3.11-3.14." >&2
  exit 69
fi

mkdir -p "$DATA_ROOT"
chmod 700 "$DATA_ROOT"

if [[ ! -e "$VENV" ]]; then
  python3 -m venv "$VENV"
fi

if [[ ! -x "$VENV/bin/python" ]]; then
  printf '%s\n' \
    "Telegram Personal runtime is invalid: $VENV/bin/python must be executable. Repair or remove $VENV manually." >&2
  exit 69
fi

if ! RUNTIME_INFO="$(
  "$VENV/bin/python" -c \
    'import sys; print(sys.version_info.major, sys.version_info.minor, int(sys.prefix != sys.base_prefix))' \
    2>/dev/null
)"; then
  printf '%s\n' \
    "Telegram Personal runtime is invalid: $VENV/bin/python could not report its Python and virtual-environment state. Repair or remove $VENV manually." >&2
  exit 69
fi

if [[ ! "$RUNTIME_INFO" =~ ^([0-9]+)[[:blank:]]([0-9]+)[[:blank:]]([01])$ ]]; then
  printf '%s\n' \
    "Telegram Personal runtime is invalid: $VENV/bin/python returned an unexpected runtime identity. Repair or remove $VENV manually." >&2
  exit 69
fi
RUNTIME_MAJOR="${BASH_REMATCH[1]}"
RUNTIME_MINOR="${BASH_REMATCH[2]}"
RUNTIME_IS_VENV="${BASH_REMATCH[3]}"

if (( RUNTIME_MAJOR != 3 || RUNTIME_MINOR < 11 || RUNTIME_MINOR > 14 )); then
  printf '%s\n' \
    "Telegram Personal runtime must use Python 3.11-3.14. Existing runtime at $VENV was not modified." >&2
  exit 69
fi

if [[ "$RUNTIME_IS_VENV" != "1" ]]; then
  printf '%s\n' \
    "Telegram Personal runtime must be a virtual environment. Existing runtime at $VENV was not modified." >&2
  exit 69
fi

"$VENV/bin/python" -m pip install -r "$PLUGIN_ROOT/requirements.txt"
exec "$VENV/bin/python" -m telegram_mcp.setup_cli "$@"
